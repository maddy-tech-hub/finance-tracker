{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=<postgres-host>;Port=5432;Database=finance_tracker;Username=<user>;Password=<password>"
  },
  "Jwt": {
    "Issuer": "FinanceTracker.Api",
    "Audience": "FinanceTracker.Frontend",
    "Key": "SET_A_SECURE_32_PLUS_CHARACTER_KEY",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 14
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-frontend-domain.example"
    ]
  },
  "UseHttpsRedirection": false
}
