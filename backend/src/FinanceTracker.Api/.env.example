# Backend environment variables (override appsettings values)
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
UseHttpsRedirection=false

# PostgreSQL
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=finance_tracker;Username=postgres;Password=postgres

# JWT
Jwt__Issuer=FinanceTracker.Api
Jwt__Audience=FinanceTracker.Frontend
Jwt__Key=CHANGE_THIS_TO_A_LONG_SECURE_KEY_FOR_PRODUCTION_32CHARS_MIN
Jwt__AccessTokenMinutes=30
Jwt__RefreshTokenDays=14

# CORS
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:4173
