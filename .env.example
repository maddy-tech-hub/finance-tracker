# Compose environment defaults
POSTGRES_DB=finance_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_ISSUER=FinanceTracker.Api
JWT_AUDIENCE=FinanceTracker.Frontend
JWT_KEY=CHANGE_THIS_TO_A_LONG_SECURE_KEY_FOR_PRODUCTION_32CHARS_MIN
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14
USE_HTTPS_REDIRECTION=false

CORS_ORIGIN_1=http://localhost:4173
CORS_ORIGIN_2=http://localhost:5173

VITE_API_URL=http://localhost:8080
